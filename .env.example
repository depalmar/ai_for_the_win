# AI for the Win - Environment Variables
# Copy this file: cp .env.example .env
# Then fill in at least ONE LLM API key for Labs 14+

# =============================================================================
# LLM API Keys (choose at least one for LLM labs)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# Optional: Threat Intelligence APIs
# =============================================================================
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# =============================================================================
# Optional: Local LLM (Ollama - no key needed, just install from ollama.ai)
# =============================================================================
# OLLAMA_HOST=http://localhost:11434
